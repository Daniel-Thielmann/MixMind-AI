# ============================================================
# MixMind AI - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values.
#   cp .env.example .env
# ============================================================

# --- Application --------------------------------------------------
APP_NAME=MixMind AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# --- API ----------------------------------------------------------
API_V1_PREFIX=/api/v1
BASE_URL=http://127.0.0.1:8000

# --- CORS ---------------------------------------------------------
CORS_ORIGINS=["http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true

# --- Paths --------------------------------------------------------
UPLOAD_DIR=uploads
PROCESSED_DIR=processed
TEMP_DIR=temp

# --- Supabase Storage ---------------------------------------------
# Use a backend-only sb_secret_... key. Never expose it to Next.js.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=mixmind-media
SUPABASE_STORAGE_ENABLED=false
SUPABASE_STORAGE_PUBLIC=false
SUPABASE_SIGNED_URL_TTL=3600
DEMO_SIGNED_URL_TTL=3600
DEMO_MANIFEST_CACHE_TTL=300

# --- Upload Limits ------------------------------------------------
MAX_UPLOAD_SIZE=100
INTERNAL_AUTH_SECRET=

# --- LLM / OpenRouter ---------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free

LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_BASE=1.0
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.0
LLM_LOG_RAW_RESPONSES=false

# --- Spotify Integration -------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/integrations/spotify/callback
SPOTIFY_SCOPES=user-read-private user-read-email

FRONTEND_URL=http://127.0.0.1:3000

# Local default: sqlite:///./mixmind.db
# Supabase/PostgreSQL URLs are normalized to the psycopg driver automatically.
DATABASE_URL=sqlite:///./mixmind.db
